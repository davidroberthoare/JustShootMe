# Copy to .env and fill in real values. Never commit .env.

APP_ENV=production
APP_DEBUG=false
APP_URL=https://justshootme.example.com

# Secret used to sign archive-download URLs and session tokens. Generate with:
#   php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=changeme

# SQLite database file (relative to project root, outside public/)
DB_PATH=storage/justshootme.sqlite

# Storage locations (outside public/ so files aren't served directly)
STORAGE_EVENTS_PATH=storage/events
STORAGE_ARCHIVES_PATH=storage/archives
STORAGE_LOGOS_PATH=storage/logos

# Amazon SES via SMTP interface (https://docs.aws.amazon.com/ses/latest/dg/send-email-smtp.html)
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USERNAME=changeme
SES_SMTP_PASSWORD=changeme
SES_FROM_EMAIL=justshootme@example.com
SES_FROM_NAME="JustShootMe"

# Retention / lifecycle tuning (see spec: two-stage retention)
RETENTION_ACTIVE_DAYS=7
RETENTION_ARCHIVE_DAYS=7
RETENTION_DOWNLOAD_GRACE_HOURS=1

# Default per-event caps (overridable per event at creation time)
DEFAULT_EVENT_PHOTO_CAP=200
DEFAULT_EVENT_STORAGE_CAP_MB=500

# Global storage cap across all active events (0 = unlimited). When reached,
# new event creation is blocked and the admin is alerted (see spec decision).
GLOBAL_STORAGE_CAP_MB=10240

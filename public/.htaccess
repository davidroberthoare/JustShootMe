RewriteEngine On

# The docroot has both index.html (kiosk landing page) and index.php (Slim
# front controller) side by side, so "/" is ambiguous. Route it to
# index.html explicitly via mod_rewrite rather than a DirectoryIndex
# directive — DirectoryIndex needs "AllowOverride Indexes", which many
# hardened vhosts don't grant, and an unpermitted directive makes Apache
# treat the whole .htaccess as invalid (500 on every request, not just "/").
RewriteRule ^$ index.html [L]

# Serve real files/directories (static booth/admin/photo pages, assets) directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else goes through the Slim front controller.
RewriteRule ^ index.php [QSA,L]
